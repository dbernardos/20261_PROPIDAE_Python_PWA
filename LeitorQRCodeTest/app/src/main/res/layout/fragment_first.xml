<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    tools:context=".FirstFragment">

    <!-- 1. CABEÇALHO (20% da tela) -->
    <!-- Verde escuro do colóquio -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:background="#1B5E20"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/logocoloquio" />
    </LinearLayout>

    <!-- 2. CONTEÚDO PRINCIPAL (60% da tela) -->
    <!-- Verde lima vibrante -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#9ACD32">

        <!-- Texto Chamativo com cor escura para contraste -->

        <!-- Botão com contraste forte -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <Button
                android:id="@+id/lerQRCodeButton"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:backgroundTint="#1B5E20"
                android:elevation="10dp"
                android:fontFamily="sans-serif-black"
                android:padding="15dp"
                android:stateListAnimator="@null"
                android:text="@string/txtJogarQuiz"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/textoLidoTextView"
                android:layout_width="221dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp"
                android:fontFamily="sans-serif-medium"
                android:textAlignment="center"
                android:textColor="#1B5E20"
                android:textSize="24sp"
                android:textStyle="bold" />

            <com.journeyapps.barcodescanner.DecoratedBarcodeView
                android:id="@+id/barcodeView"
                android:layout_width="300dp"
                android:layout_height="400dp"
                android:layout_marginTop="32dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textoLidoTextView"
                app:zxing_preview_scaling_strategy="centerCrop"
                app:zxing_use_texture_view="false" />
        </LinearLayout>

    </LinearLayout>

    <!-- 3. RODAPÉ (20% da tela) -->
    <!-- Mesmo tom escuro do cabeçalho para equilíbrio visual -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:background="#1B5E20"
        android:orientation="horizontal">

        <!-- Logos dos Patrocinadores com filtro branco para harmonia -->
        <ImageView
            android:layout_width="185dp"
            android:layout_height="50dp"
            android:layout_margin="10dp"
            android:alpha="0.9"
            android:contentDescription="Logo 1"
            android:src="@drawable/logoifsc" />

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_launcher_foreground"
            android:layout_margin="10dp"
            android:contentDescription="Logo 2"
            android:alpha="0.9"/>

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_launcher_foreground"
            android:layout_margin="10dp"
            android:contentDescription="Logo 3"
            android:alpha="0.9"/>

    </LinearLayout>

</LinearLayout>